### Register a new user
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "test@example.com",
  "password": "Test1234!"
}

### Login (stores access_token and refresh_token)
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "Test1234!"
}

> {%
    client.global.set("access_token", response.body.accessToken);
    client.global.set("refresh_token", response.body.refreshToken);
%}

### Get current user (requires token from Login)
GET http://localhost:8080/api/auth/me
Authorization: Bearer {{access_token}}

### Refresh access token
POST http://localhost:8080/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}

### Logout (revokes session)
POST http://localhost:8080/api/auth/logout
Authorization: Bearer {{access_token}}

### Get user by ID (replace UUID)
GET http://localhost:8080/api/users/REPLACE_WITH_UUID
Authorization: Bearer {{access_token}}

### Update user (replace UUID)
PUT http://localhost:8080/api/users
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "id": "REPLACE_WITH_UUID",
  "username": "updateduser",
  "email": "updated@example.com"
}

### Delete user (replace UUID)
DELETE http://localhost:8080/api/users/REPLACE_WITH_UUID
Authorization: Bearer {{access_token}}
